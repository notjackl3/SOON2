{
  "name": "soon-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:smoke": "playwright test smoke",
    "test:perf": "playwright test performance --project=desktop",
    "test:lh": "playwright test lighthouse --project=desktop",
    "test:visual": "playwright test visual",
    "test:update": "playwright test visual --update-snapshots",
    "test:report": "playwright show-report",
    "optimize:glb": "gltf-transform optimize public/models/scene.glb public/models/scene.tmp.glb --simplify false --texture-compress webp --texture-size 2048 && mv -f public/models/scene.tmp.glb public/models/scene.glb"
  },
  "dependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.110.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.21.0",
    "maath": "^0.10.8",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.1",
    "playwright-lighthouse": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
